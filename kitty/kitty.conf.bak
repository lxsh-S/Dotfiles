# vim:fileencoding=utf-8:foldmethod=marker

# BEGIN_KITTY_THEME
# Batman
include current-theme.conf
# END_KITTY_THEME

# Fonts 
font_family      JetBrainsMono Nerd Font Mono 
bold_font        auto
italic_font      auto
bold_italic_font auto
font_size        15.0

# Cursor
shell_integration disabled
cursor_shape block
cursor_blink_interval -1
cursor_stop_blinking_after 15.0
# cursor_trail                 3
# cursor_trail_decay           0.1 0.4
# cursor_trail_start_threshold 2
#
# Mouse
mouse_hide_wait  3.0
# url_color        #0087bd
url_style        curly
open_url_with    default

# Scroll History & Performance
scrollback_lines         10000
scrollback_pager_history_size 20

# Mouse Scroll Multipliers (Adjust Speed)
wheel_scroll_multiplier  4.0
touch_scroll_multiplier  2.0

# Mouse Actions (Smooth Tracking)
mouse_hide_wait          0
focus_follows_mouse      yes

# Window Layout & Padding
remember_window_size   no
initial_window_width   820
initial_window_height  500
window_padding_width   12
hide_window_decorations no
confirm_os_window_close 0

# Tab Bar
tab_bar_style        powerline
tab_powerline_style  slanted

# Performance & Bells
sync_to_monitor      no
enable_audio_bell    no

# Theme & Background
background_opacity       1
background_blur          0
# (Uncomment the line below if you downloaded a specific theme)
# include current-theme.conf

# Keybindings
map ctrl+shift+c        copy_to_clipboard
map ctrl+shift+v        paste_from_clipboard
map ctrl+shift+t        new_tab
map ctrl+shift+q        close_window
